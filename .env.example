# Proxmox Connection
PROXMOX_HOST=192.168.1.11
PROXMOX_PORT=8006

# API Token (from Proxmox user creation)
# Format: user@realm!tokenname
PROXMOX_TOKEN_ID=mcp-service@pve!mcp-token
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# JWT Authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-minimum-32-character-secret-key-here

# Operation Control
# Comma-separated list of allowed MCP operations
ALLOWED_OPERATIONS=vm.list,vm.status,vm.start,vm.stop,vm.shutdown,node.list,node.status,storage.list,backup.list,backup.status

# Logging
LOG_LEVEL=INFO