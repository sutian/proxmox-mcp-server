# ============================================================
# Proxmox MCP Server - Environment Configuration
# Version 1.1.0 - Multi-Host Support
# ============================================================

# ============================================================
# Option A: Multi-Host Configuration (Recommended)
# ============================================================
# Format: node_name:host:port,node_name:host:port
# Port is optional (defaults to 8006)
PROXMOX_NODES=pve11:IP_11:8006,pve12:IP_12:8006,pve13:IP_13:8006

# Shared API token (used if no per-node token specified)
# Format: user@realm!tokenname
PROXMOX_TOKEN_ID=mcp-service@pve!mcp-token
PROXMOX_TOKEN_SECRET=your-token-secret-here

# Option B: Per-node token overrides (only if different nodes use different tokens)
# Format: node_name=token_id:token_secret,node_name=token_id:token_secret
# PROXMOX_NODE_TOKENS=pve11=user@realm!token1=secret1,pve12=user@realm!token2=secret2

# ============================================================
# Legacy Single-Host (Backward Compatible)
# Only used if PROXMOX_NODES is not set
# ============================================================
# PROXMOX_HOST=192.168.1.11
# PROXMOX_PORT=8006

# ============================================================
# TLS Verification
# Set to "false" if using self-signed certificates
# ============================================================
VERIFY_TLS=true

# ============================================================
# JWT Authentication
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-minimum-32-character-secret-key-here

# ============================================================
# User Authentication
# Passwords must be at least 8 characters
# ============================================================
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
OPERATOR_PASSWORD=CHANGE_ME_OPERATOR_PASSWORD
VIEWER_PASSWORD=CHANGE_ME_VIEWER_PASSWORD

# ============================================================
# Operation Control
# ============================================================
ALLOWED_OPERATIONS=vm.list,vm.status,vm.start,vm.stop,vm.shutdown,vm.create,vm.clone,vm.modify,vm.snapshot,vm.snapshot.create,node.list,node.status,storage.list,backup.list,backup.status,vm.migrate,cluster.status,cluster.config,cluster.resources,cluster.members,vm.powermgmt

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
