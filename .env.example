# Proxmox Connection
PROXMOX_HOST=192.168.1.11
PROXMOX_PORT=8006

# API Token (from Proxmox user creation)
# Format: user@realm!tokenname
PROXMOX_TOKEN_ID=root@pam!api-token-pve11
PROXMOX_TOKEN_SECRET=your-token-secret-here

# JWT Authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-minimum-32-character-secret-key-here

# User Authentication (set strong passwords!)
# Passwords must be at least 8 characters
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
OPERATOR_PASSWORD=CHANGE_ME_OPERATOR_PASSWORD
VIEWER_PASSWORD=CHANGE_ME_VIEWER_PASSWORD

# Operation Control
# Comma-separated list of allowed MCP operations
ALLOWED_OPERATIONS=vm.list,vm.status,vm.start,vm.stop,vm.shutdown,vm.create,vm.clone,node.list,node.status,storage.list,backup.list,backup.status

# Logging
LOG_LEVEL=INFO
